<%- include('partials/header') %>
    <main class="container">

        <!-- Hero -->
        <div class="ds-hero">
            <div class="ds-hero-badge">Design System v1.0</div>
            <h1>Kwiki Bank</h1>
            <p>Standardized components for building internal and customer-facing applications.</p>
        </div>

        <!-- Colors -->
        <section class="ds-section">
            <div class="ds-section-title">Color Palette</div>
            <div class="ds-colors">
                <div class="ds-color-group">
                    <div class="ds-color-swatch" style="background: var(--primary-800)"></div>
                    <div class="ds-color-info">
                        <div class="ds-color-name">Primary</div>
                        <div class="ds-color-value">#0f2039</div>
                    </div>
                </div>
                <div class="ds-color-group">
                    <div class="ds-color-swatch" style="background: linear-gradient(135deg, var(--accent-500), var(--accent-400))"></div>
                    <div class="ds-color-info">
                        <div class="ds-color-name">Accent / Gold</div>
                        <div class="ds-color-value">#c9a227</div>
                    </div>
                </div>
                <div class="ds-color-group">
                    <div class="ds-color-swatch" style="background: var(--success-500)"></div>
                    <div class="ds-color-info">
                        <div class="ds-color-name">Success</div>
                        <div class="ds-color-value">#16a34a</div>
                    </div>
                </div>
                <div class="ds-color-group">
                    <div class="ds-color-swatch" style="background: var(--warning-500)"></div>
                    <div class="ds-color-info">
                        <div class="ds-color-name">Warning</div>
                        <div class="ds-color-value">#f59e0b</div>
                    </div>
                </div>
                <div class="ds-color-group">
                    <div class="ds-color-swatch" style="background: var(--danger-500)"></div>
                    <div class="ds-color-info">
                        <div class="ds-color-name">Danger</div>
                        <div class="ds-color-value">#ef4444</div>
                    </div>
                </div>
                <div class="ds-color-group">
                    <div class="ds-color-swatch" style="background: var(--info-500)"></div>
                    <div class="ds-color-info">
                        <div class="ds-color-name">Info</div>
                        <div class="ds-color-value">#0ea5e9</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Typography -->
        <section class="ds-section">
            <div class="ds-section-title">Typography</div>
            <div class="ds-type-card">
                <div class="ds-type-row">
                    <div class="ds-type-label">Heading 1</div>
                    <div class="ds-type-sample ds-type-h1">Account Overview</div>
                </div>
                <div class="ds-type-row">
                    <div class="ds-type-label">Heading 2</div>
                    <div class="ds-type-sample ds-type-h2">Transaction History</div>
                </div>
                <div class="ds-type-row">
                    <div class="ds-type-label">Heading 3</div>
                    <div class="ds-type-sample ds-type-h3">Recent Activity</div>
                </div>
                <div class="ds-type-row">
                    <div class="ds-type-label">Body</div>
                    <div class="ds-type-sample ds-type-body">Your account balance has been updated. All pending transactions are now reflected in your statement.</div>
                </div>
                <div class="ds-type-row">
                    <div class="ds-type-label">Small</div>
                    <div class="ds-type-sample ds-type-small">Last updated: Feb 25, 2026 at 3:45 PM</div>
                </div>
                <div class="ds-type-row">
                    <div class="ds-type-label">Monospace</div>
                    <div class="ds-type-sample"><code class="ds-type-mono">TXN-2026-0225-4891</code></div>
                </div>
            </div>
        </section>

        <!-- Buttons -->
        <section class="ds-section">
            <div class="ds-section-title">Buttons</div>
            <div class="ds-button-card">
                <div class="ds-button-row">
                    <div class="ds-button-row-label">Primary actions</div>
                    <button class="btn btn-primary">Confirm Transfer</button>
                    <button class="btn btn-accent">Upgrade Plan</button>
                    <button class="btn btn-success">Approve</button>
                    <button class="btn btn-danger">Decline</button>
                </div>
                <div class="ds-button-row">
                    <div class="ds-button-row-label">Secondary actions</div>
                    <button class="btn btn-outline">View Details</button>
                    <button class="btn btn-ghost">Cancel</button>
                </div>
                <div class="ds-button-row">
                    <div class="ds-button-row-label">Sizes</div>
                    <button class="btn btn-primary btn-sm">Small</button>
                    <button class="btn btn-primary">Default</button>
                    <button class="btn btn-primary btn-lg">Large</button>
                </div>
            </div>
        </section>

        <!-- Badges -->
        <section class="ds-section">
            <div class="ds-section-title">Badges &amp; Status</div>
            <div class="ds-badges-card">
                <div class="ds-badge-row" style="margin-bottom: 1rem;">
                    <span class="badge badge-primary">Account</span>
                    <span class="badge badge-accent">Gold Tier</span>
                    <span class="badge badge-success">Approved</span>
                    <span class="badge badge-warning">Pending Review</span>
                    <span class="badge badge-danger">Overdue</span>
                    <span class="badge badge-info">Processing</span>
                </div>
                <div class="ds-badge-row">
                    <span class="badge badge-success badge-dot">Online</span>
                    <span class="badge badge-warning badge-dot">Maintenance</span>
                    <span class="badge badge-danger badge-dot">Offline</span>
                    <span class="badge badge-info badge-dot">Syncing</span>
                </div>
            </div>
        </section>

        <!-- Alerts -->
        <section class="ds-section">
            <div class="ds-section-title">Alerts</div>
            <div class="ds-alerts">
                <div class="alert alert-success">
                    <span class="alert-icon">&#10003;</span>
                    <span>Transfer of $2,500.00 to savings account completed successfully.</span>
                </div>
                <div class="alert alert-info">
                    <span class="alert-icon">&#9432;</span>
                    <span>Your monthly statement is ready for download.</span>
                </div>
                <div class="alert alert-warning">
                    <span class="alert-icon">&#9888;</span>
                    <span>Your session will expire in 5 minutes. Please save your work.</span>
                </div>
                <div class="alert alert-danger">
                    <span class="alert-icon">&#10007;</span>
                    <span>Payment failed. Please check your card details and try again.</span>
                </div>
            </div>
        </section>

        <!-- Form Elements -->
        <section class="ds-section">
            <div class="ds-section-title">Form Elements</div>
            <div class="ds-form-card">
                <div class="ds-form-grid">
                    <div class="form-group">
                        <label class="form-label">Account Holder</label>
                        <input class="form-input" type="text" placeholder="Full legal name">
                        <span class="form-hint">As it appears on your ID</span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <input class="form-input" type="email" placeholder="you@example.com">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Account Type</label>
                        <select class="form-select">
                            <option>Checking Account</option>
                            <option>Savings Account</option>
                            <option>Business Account</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Transfer Amount</label>
                        <input class="form-input" type="text" placeholder="$0.00">
                    </div>
                </div>
            </div>
        </section>

        <!-- Cards -->
        <section class="ds-section">
            <div class="ds-section-title">Cards</div>
            <div class="ds-cards-grid">
                <div class="card card-accent-top">
                    <div class="card-body">
                        <div class="card-title">Checking Account</div>
                        <div class="card-subtitle">****4891</div>
                        <div class="card-text" style="font-size: 1.75rem; font-weight: 800; color: var(--primary-800);">$12,450.00</div>
                    </div>
                    <div class="card-footer">
                        <span class="badge badge-success badge-dot">Active</span>
                        <button class="btn btn-ghost btn-sm">View</button>
                    </div>
                </div>
                <div class="card card-accent-top">
                    <div class="card-body">
                        <div class="card-title">Savings Account</div>
                        <div class="card-subtitle">****7723</div>
                        <div class="card-text" style="font-size: 1.75rem; font-weight: 800; color: var(--primary-800);">$85,200.00</div>
                    </div>
                    <div class="card-footer">
                        <span class="badge badge-success badge-dot">Active</span>
                        <button class="btn btn-ghost btn-sm">View</button>
                    </div>
                </div>
                <div class="card card-accent-top">
                    <div class="card-body">
                        <div class="card-title">Credit Card</div>
                        <div class="card-subtitle">****3356</div>
                        <div class="card-text" style="font-size: 1.75rem; font-weight: 800; color: var(--danger-500);">-$1,890.00</div>
                    </div>
                    <div class="card-footer">
                        <span class="badge badge-warning badge-dot">Payment Due</span>
                        <button class="btn btn-ghost btn-sm">View</button>
                    </div>
                </div>
            </div>
        </section>

        <!-- Table -->
        <section class="ds-section">
            <div class="ds-section-title">Data Table</div>
            <div class="ds-table-wrapper">
                <table class="ds-table">
                    <thead>
                        <tr>
                            <th>Transaction</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="font-weight: 600;">Wire Transfer - Acme Corp</td>
                            <td>Feb 25, 2026</td>
                            <td style="font-weight: 600;">-$3,200.00</td>
                            <td><span class="badge badge-success">Completed</span></td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">Direct Deposit - Payroll</td>
                            <td>Feb 24, 2026</td>
                            <td style="font-weight: 600; color: var(--success-600);">+$5,400.00</td>
                            <td><span class="badge badge-success">Completed</span></td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">International Transfer</td>
                            <td>Feb 23, 2026</td>
                            <td style="font-weight: 600;">-$890.00</td>
                            <td><span class="badge badge-warning">Pending</span></td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">ATM Withdrawal</td>
                            <td>Feb 22, 2026</td>
                            <td style="font-weight: 600;">-$200.00</td>
                            <td><span class="badge badge-success">Completed</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

    </main>
<%- include('partials/footer') %>
